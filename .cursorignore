# Files Cursor must not index or feed to AI.
# Anything matched here is excluded from indexing.

# Secrets, credentials, certificates
*.crt
*.key
*.pem
*.p12
*.jks
*.keystore
.env
.env.*
**/.env
**/.env.*
**/certs/**
**/certificates/**
**/private/**

# Salesforce auth and sensitive metadata
**/namedCredentials/**
**/externalCredentials/**
**/connectedApps/**
**/authproviders/**
**/Integration_Metadata.*.md-meta.xml

# Real or exported data that may contain PII
data/
**/data/**
*.csv
*.xls
*.xlsx
*.tsv
*.bak
*.dump
*.sql
**/dataExport/**
**/exports/**
**/reports/**

# Salesforce build, cache, auth state
.sf/
.sfdx/
.localdevserver/
retrieved/
toDeploy/
delta/
coverage/
reports/
dist/
build/
node_modules/
